groups:
  - name: hardware-basic
    rules:
      - alert: SmartctlExporterDown
        expr: up{job="smartctl"} == 0
        for: 5m
        labels:
          severity: critical
        annotations:
          summary: "smartctl exporter down on {% raw %}{{ $labels.instance }}{% endraw %}"
          description: "Prometheus cannot scrape smartctl exporter on {% raw %}{{ $labels.instance }}{% endraw %}."

      - alert: DiskSmartFailed
        expr: smartctl_device_smart_status{job="smartctl"} == 0
        for: 5m
        labels:
          severity: critical
        annotations:
          summary: "Disk SMART failure on {% raw %}{{ $labels.instance }}{% endraw %}"
          description: "Disk {% raw %}{{ $labels.device }}{% endraw %} reported SMART failure."

      - alert: DiskSmartUnhealthy
        expr: smartmon_device_smart_healthy{job="smartctl"} == 0
        for: 5m
        labels:
          severity: critical
        annotations:
          summary: "Disk SMART unhealthy on {% raw %}{{ $labels.instance }}{% endraw %}"
          description: "Disk {% raw %}{{ $labels.disk }}{% endraw %} reports unhealthy SMART status."

      - alert: DiskTemperatureHigh
        expr: smartctl_device_temperature{job="smartctl"} > 50
        for: 10m
        labels:
          severity: warning
        annotations:
          summary: "Disk temperature high on {% raw %}{{ $labels.instance }}{% endraw %}"
          description: "Disk {% raw %}{{ $labels.device }}{% endraw %} temperature is {% raw %}{{ $value }}{% endraw %}°C."

      - alert: DiskTemperatureCritical
        expr: smartctl_device_temperature{job="smartctl"} > 60
        for: 5m
        labels:
          severity: critical
        annotations:
          summary: "Disk temperature critical on {% raw %}{{ $labels.instance }}{% endraw %}"
          description: "Disk {% raw %}{{ $labels.device }}{% endraw %} temperature is {% raw %}{{ $value }}{% endraw %}°C."

      - alert: DiskReallocatedSectors
        expr: smartmon_reallocated_sector_ct_raw_value{job="smartctl"} > 0
        for: 15m
        labels:
          severity: warning
        annotations:
          summary: "Disk has reallocated sectors on {% raw %}{{ $labels.instance }}{% endraw %}"
          description: "Disk {% raw %}{{ $labels.disk }}{% endraw %} has reallocated sectors."

      - alert: DiskPendingSectors
        expr: smartmon_current_pending_sector_raw_value{job="smartctl"} > 0
        for: 15m
        labels:
          severity: critical
        annotations:
          summary: "Disk has pending sectors on {% raw %}{{ $labels.instance }}{% endraw %}"
          description: "Disk {% raw %}{{ $labels.disk }}{% endraw %} has pending sectors."

      - alert: DiskOfflineUncorrectable
        expr: smartmon_offline_uncorrectable_raw_value{job="smartctl"} > 0
        for: 15m
        labels:
          severity: critical
        annotations:
          summary: "Disk has offline uncorrectable sectors on {% raw %}{{ $labels.instance }}{% endraw %}"
          description: "Disk {% raw %}{{ $labels.disk }}{% endraw %} has offline uncorrectable sectors."

      - alert: DiskUdmaCrcErrors
        expr: smartmon_udma_crc_error_count_raw_value{job="smartctl"} > 0
        for: 30m
        labels:
          severity: warning
        annotations:
          summary: "Disk UDMA CRC errors on {% raw %}{{ $labels.instance }}{% endraw %}"
          description: "Disk {% raw %}{{ $labels.disk }}{% endraw %} has UDMA CRC errors. Check cable/backplane/link quality."

      - alert: NodeIPMITemperatureHigh
        expr: node_ipmi_temperature_celsius{job="node"} > 70
        for: 10m
        labels:
          severity: warning
        annotations:
          summary: "IPMI temperature high on {% raw %}{{ $labels.instance }}{% endraw %}"
          description: "Sensor {% raw %}{{ $labels.name }}{% endraw %} is reading {% raw %}{{ $value }}{% endraw %}°C."

      - alert: NodeIPMITemperatureCritical
        expr: node_ipmi_temperature_celsius{job="node"} > 85
        for: 5m
        labels:
          severity: critical
        annotations:
          summary: "IPMI temperature critical on {% raw %}{{ $labels.instance }}{% endraw %}"
          description: "Sensor {% raw %}{{ $labels.name }}{% endraw %} is reading {% raw %}{{ $value }}{% endraw %}°C."

      - alert: NodeIPMISensorNotOk
        expr: node_ipmi_status{job="node"} != 0
        for: 5m
        labels:
          severity: critical
        annotations:
          summary: "IPMI sensor status not OK on {% raw %}{{ $labels.instance }}{% endraw %}"
          description: "Sensor {% raw %}{{ $labels.name }}{% endraw %} is reporting a non-OK state."

      - alert: NodeFanZeroRPM
        expr: node_ipmi_speed_rpm{job="node"} == 0
        for: 10m
        labels:
          severity: warning
        annotations:
          summary: "Fan stopped on {% raw %}{{ $labels.instance }}{% endraw %}"
          description: "Fan sensor {% raw %}{{ $labels.name }}{% endraw %} is reporting 0 RPM."

      - alert: ECCUncorrectableErrors
        expr: increase(node_edac_uncorrectable_errors_total{job="node"}[15m]) > 0
        for: 0m
        labels:
          severity: critical
        annotations:
          summary: "Uncorrectable ECC errors on {% raw %}{{ $labels.instance }}{% endraw %}"
          description: "The node has reported uncorrectable ECC memory errors."

      - alert: ECCCorrectableErrorsIncreasing
        expr: increase(node_edac_correctable_errors_total{job="node"}[1h]) > 0
        for: 0m
        labels:
          severity: warning
        annotations:
          summary: "Correctable ECC errors increasing on {% raw %}{{ $labels.instance }}{% endraw %}"
          description: "The node has reported new correctable ECC memory errors in the last hour."

      - alert: ZfsArcMemoryPressure
        expr: node_zfs_arc_memory_throttle_count{job="node"} > 0
        for: 10m
        labels:
          severity: warning
        annotations:
          summary: "ZFS ARC memory throttling on {% raw %}{{ $labels.instance }}{% endraw %}"
          description: "ZFS ARC is reporting memory pressure/throttling."