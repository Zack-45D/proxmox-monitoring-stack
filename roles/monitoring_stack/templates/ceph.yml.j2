groups:
- name: ceph-basic
  rules:
  - alert: CephHealthWarning
    expr: ceph_health_status == 1
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: "Ceph health is WARNING"
      description: "Ceph cluster health status is WARN."

  - alert: CephHealthError
    expr: ceph_health_status == 2
    for: 2m
    labels:
      severity: critical
    annotations:
      summary: "Ceph health is ERROR"
      description: "Ceph cluster health status is ERR."

  - alert: CephOSDDown
    expr: ceph_osd_up == 0
    for: 2m
    labels:
      severity: critical
    annotations:
      summary: "Ceph OSD down"
      description: "One or more Ceph OSDs are down."

  - alert: CephOSDOut
    expr: ceph_osd_in == 0
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: "Ceph OSD out"
      description: "One or more Ceph OSDs are marked out."

  - alert: CephDegradedObjects
    expr: ceph_pg_degraded > 0
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: "Ceph degraded PGs detected"
      description: "Ceph has degraded placement groups."

  - alert: CephMisplacedObjects
    expr: ceph_pg_misplaced > 0
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: "Ceph misplaced PGs detected"
      description: "Ceph has misplaced placement groups."

  - alert: CephRecoveryActiveTooLong
    expr: ceph_pg_recovering > 0
    for: 30m
    labels:
      severity: warning
    annotations:
      summary: "Ceph recovery ongoing for extended period"
      description: "Ceph recovery has been active for more than 30 minutes."