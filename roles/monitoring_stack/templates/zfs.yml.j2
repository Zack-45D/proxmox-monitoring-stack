groups:
  - name: zfs-health
    rules:
      - alert: ZfsPoolNotOnline
        expr: zfs_pool_health{state="ONLINE"} == 0
        for: 2m
        labels:
          severity: critical
        annotations:
          summary: "ZFS pool unhealthy on {{ \"{{ $labels.instance }}\" }}"
          description: "Pool {{ \"{{ $labels.pool }}\" }} is not ONLINE."

      - alert: ZfsPoolReadErrors
        expr: zfs_pool_read_errors > 0
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "ZFS pool read errors on {{ \"{{ $labels.instance }}\" }}"
          description: "Pool {{ \"{{ $labels.pool }}\" }} has read errors."

      - alert: ZfsPoolWriteErrors
        expr: zfs_pool_write_errors > 0
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "ZFS pool write errors on {{ \"{{ $labels.instance }}\" }}"
          description: "Pool {{ \"{{ $labels.pool }}\" }} has write errors."

      - alert: ZfsPoolChecksumErrors
        expr: zfs_pool_checksum_errors > 0
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "ZFS pool checksum errors on {{ \"{{ $labels.instance }}\" }}"
          description: "Pool {{ \"{{ $labels.pool }}\" }} has checksum errors."

      - alert: ZfsVdevNotOnline
        expr: zfs_vdev_health{state="ONLINE"} == 0
        for: 2m
        labels:
          severity: critical
        annotations:
          summary: "ZFS vdev unhealthy on {{ \"{{ $labels.instance }}\" }}"
          description: "Vdev {{ \"{{ $labels.vdev }}\" }} in pool {{ \"{{ $labels.pool }}\" }} is not ONLINE."

      - alert: ZfsVdevReadErrors
        expr: zfs_vdev_read_errors > 0
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "ZFS vdev read errors on {{ \"{{ $labels.instance }}\" }}"
          description: "Vdev {{ \"{{ $labels.vdev }}\" }} in pool {{ \"{{ $labels.pool }}\" }} has read errors."

      - alert: ZfsVdevWriteErrors
        expr: zfs_vdev_write_errors > 0
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "ZFS vdev write errors on {{ \"{{ $labels.instance }}\" }}"
          description: "Vdev {{ \"{{ $labels.vdev }}\" }} in pool {{ \"{{ $labels.pool }}\" }} has write errors."

      - alert: ZfsVdevChecksumErrors
        expr: zfs_vdev_checksum_errors > 0
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "ZFS vdev checksum errors on {{ \"{{ $labels.instance }}\" }}"
          description: "Vdev {{ \"{{ $labels.vdev }}\" }} in pool {{ \"{{ $labels.pool }}\" }} has checksum errors."