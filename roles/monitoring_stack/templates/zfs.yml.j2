groups:
  - name: zfs-health
    rules:
      - alert: ZfsPoolNotOnline
        expr: zfs_pool_health{state="ONLINE"} == 0
        for: 2m
        labels:
          severity: critical
        annotations:
          summary: "ZFS pool unhealthy on {% raw %}{{ $labels.instance }}{% endraw %}"
          description: "Pool {% raw %}{{ $labels.pool }}{% endraw %} is not ONLINE."

      - alert: ZfsPoolReadErrors
        expr: zfs_pool_read_errors > 0
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "ZFS pool read errors on {% raw %}{{ $labels.instance }}{% endraw %}"
          description: "Pool {% raw %}{{ $labels.pool }}{% endraw %} has read errors."

      - alert: ZfsPoolWriteErrors
        expr: zfs_pool_write_errors > 0
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "ZFS pool write errors on {% raw %}{{ $labels.instance }}{% endraw %}"
          description: "Pool {% raw %}{{ $labels.pool }}{% endraw %} has write errors."

      - alert: ZfsPoolChecksumErrors
        expr: zfs_pool_checksum_errors > 0
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "ZFS pool checksum errors on {% raw %}{{ $labels.instance }}{% endraw %}"
          description: "Pool {% raw %}{{ $labels.pool }}{% endraw %} has checksum errors."

      - alert: ZfsVdevNotOnline
        expr: zfs_vdev_health{state="ONLINE"} == 0
        for: 2m
        labels:
          severity: critical
        annotations:
          summary: "ZFS vdev unhealthy on {% raw %}{{ $labels.instance }}{% endraw %}"
          description: "Vdev {% raw %}{{ $labels.vdev }}{% endraw %} in pool {% raw %}{{ $labels.pool }}{% endraw %} is not ONLINE."

      - alert: ZfsVdevReadErrors
        expr: zfs_vdev_read_errors > 0
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "ZFS vdev read errors on {% raw %}{{ $labels.instance }}{% endraw %}"
          description: "Vdev {% raw %}{{ $labels.vdev }}{% endraw %} in pool {% raw %}{{ $labels.pool }}{% endraw %} has read errors."

      - alert: ZfsVdevWriteErrors
        expr: zfs_vdev_write_errors > 0
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "ZFS vdev write errors on {% raw %}{{ $labels.instance }}{% endraw %}"
          description: "Vdev {% raw %}{{ $labels.vdev }}{% endraw %} in pool {% raw %}{{ $labels.pool }}{% endraw %} has write errors."

      - alert: ZfsVdevChecksumErrors
        expr: zfs_vdev_checksum_errors > 0
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "ZFS vdev checksum errors on {% raw %}{{ $labels.instance }}{% endraw %}"
          description: "Vdev {% raw %}{{ $labels.vdev }}{% endraw %} in pool {% raw %}{{ $labels.pool }}{% endraw %} has checksum errors."